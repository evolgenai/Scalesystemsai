generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

}



enum AgentStatus {

  IDLE

  PLANNING

  EXECUTING

  REFLECTING

  ACTIVE

  PAUSED

  ERROR

}



enum UserRole {

  USER

  SUPER_ADMIN

}



enum SubscriptionTier {

  STARTER_5

  GROWTH_10

  PRO_20

  SCALE_50

  ENTERPRISE_100

  OVERLORD_500

}



enum OrgRole {

  OWNER

  ADMIN

  MEMBER

}



model User {

  id           String           @id @default(cuid())

  name         String?

  email        String           @unique

  phone        String?

  password     String

  role         UserRole         @default(USER)

  tier         SubscriptionTier @default(STARTER_5)

  maxAgents    Int              @default(5)

  plan         String           @default("FREE")

  emailCode           String?
  emailCodeExpiresAt  DateTime?
  phoneCode           String?
  phoneCodeExpiresAt  DateTime?
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?

  agents       Agent[]

  swarmSessions SwarmSession[]

  memberships  OrgMembership[]

  workspaceMemories WorkspaceMemory[]

  agentTokens  AgentTokenVault[]

  mcpHosts     McpHost[]

  subscription Subscription?

  createdAt    DateTime         @default(now())

  updatedAt    DateTime         @updatedAt

}



model Subscription {

  id        String           @id @default(cuid())

  userId    String           @unique

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier      SubscriptionTier

  maxAgents Int

  status    String           @default("active")

  createdAt DateTime         @default(now())

  updatedAt DateTime         @updatedAt

}



model Agent {

  id          String      @id @default(cuid())

  name        String

  status      AgentStatus @default(IDLE)

  objective   String

  currentTask String?

  memoryBank  Json        @default("[]")

  ownerId     String?

  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())

  updatedAt   DateTime    @updatedAt



  @@index([ownerId])

}

model SystemSnapshot {
  id                String   @id @default(uuid())
  branch            String
  lastCommit        String
  activeAgentsCount Int
  timestamp         DateTime @default(now())
}

model SwarmSession {
  id                     String   @id @default(cuid())
  userId                 String
  orgId                  String?
  objective              String
  resultMarkdown         String   @db.Text
  kernelLogs             String   @db.Text
  /** ACTIVE | PAUSED | PENDING_CONSENSUS | COMPLETED | FAILED | TIMEOUT */
  status                 String   @default("COMPLETED")
  /** Operator HITL directive; cleared after the stream loop consumes it. */
  interventionDirective  String?  @db.Text
  /** Human debate vote: creator | critic — cleared after the loop consumes it. */
  consensusVote          String?
  /** Wall-clock duration of the swarm run in milliseconds. */
  durationMs             Int      @default(0)
  /** Execution credit units consumed by this run. */
  creditsUsed            Int      @default(0)
  /** Optional tokens estimate (chars/4 heuristic when provider tokens unavailable). */
  tokensUsed             Int      @default(0)
  /** Persona label used for the run (Researcher, Security, Custom, …). */
  persona                String?
  /** True when the run entered PAUSED / received an operator intervention. */
  hitlUsed               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([userId, orgId, createdAt])
  @@index([orgId, createdAt])
  @@index([createdAt])
  @@index([status])
}

model Organization {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships OrgMembership[]
  sessions    SwarmSession[]
  memories    WorkspaceMemory[]
  plugins     WorkspacePlugin[]
  agentTokens AgentTokenVault[]
  mcpHosts    McpHost[]
}

enum AgentTokenKind {
  LIVE
  TEST
  SERVICE
}

/**
 * Token Vault — store keyPrefix + keyHash + sealed Edge claims only.
 * Never persist raw ss_live_* secrets. sealedPayload uses ss:iv:tag:cipher.
 */
model AgentTokenVault {
  id            String         @id @default(cuid())
  keyPrefix     String
  keyHash       String         @unique
  sealedPayload String
  kind          AgentTokenKind @default(LIVE)
  label         String?
  scopes        String[]
  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orgId         String?
  organization  Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expiresAt     DateTime?
  revokedAt     DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
  @@index([orgId])
  @@index([keyPrefix])
  @@index([revokedAt])
  @@index([workspaceId])
}

enum McpTransportKind {
  HTTP
  SSE
}

/**
 * Registered remote MCP hosts (streamable HTTP / SSE).
 * authTokenCipher uses the same AES-GCM envelope as WorkspacePlugin.authToken.
 */
model McpHost {
  id              String           @id @default(cuid())
  name            String
  url             String
  transport       McpTransportKind @default(HTTP)
  authTokenCipher String?
  isActive        Boolean          @default(true)
  orgId           String?
  organization    Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId         String?
  owner           User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspaceId     String?
  workspace       Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lastToolListAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([orgId, isActive])
  @@index([ownerId])
  @@index([workspaceId, isActive])
}

/**
 * External OpenAPI-backed tools scoped to a workspace (Organization).
 * authToken is AES-256-GCM ciphertext with an "ss..." prefix when present.
 */
model WorkspacePlugin {
  id          String        @id @default(uuid())
  name        String
  /** Parsed OpenAPI paths & schemas for dynamic tool compilation. */
  spec        Json
  baseUrl     String
  /** "none" | "bearer" | "apiKey" */
  authType    String
  /** e.g. "Authorization" or "x-api-key" */
  authHeader  String
  /** Securely encrypted string with "ss..." prefix; null when authType is "none". */
  authToken   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspaceId String?
  workspace   Organization? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model WorkspaceMemory {
  id        String        @id @default(cuid())
  orgId     String?
  userId    String
  fragment  String        @db.Text
  keywords  String[]
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([createdAt])
}

model OrgMembership {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  role         OrgRole      @default(MEMBER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

/**
 * Multi-tenant heal / MCP scope. apiKey authenticates workspace-scoped telemetry + heal.
 * credentialCipher holds AES-256-GCM sealed injection secrets (ssv1:…); never return raw.
 */
model Workspace {
  id                String               @id @default(uuid())
  name              String
  apiKey            String               @unique
  /** Sealed tenant credential blob (vault AES-256-GCM). */
  credentialCipher  String?              @db.Text
  /** Prepaid utility balance in USD for metered agent execution. */
  meterBalanceUsd   Float                @default(25)
  /** Lifetime metered spend in USD. */
  meterSpendUsd     Float                @default(0)
  meterLastAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  logs              AppErrorLog[]
  hosts             McpHost[]
  tokens            AgentTokenVault[]
  devices           EstateDevice[]
  plugins           AgentPlugin[]
  meterEvents       WorkspaceMeterEvent[]
  alertRules        TelemetryAlertRule[]

  @@index([createdAt])
  @@index([meterLastAt])
}

/**
 * Micro-transaction log for utility-metered execution (heal, sandbox, plugins).
 * No credential material — fee breakdown only.
 */
model WorkspaceMeterEvent {
  id                 String    @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** heal | sandbox | manual | plugin */
  source             String
  referenceId        String?
  inputTokens        Int       @default(0)
  correctionCycles   Int       @default(0)
  notificationsSent  Int       @default(0)
  pluginsInvoked     Int       @default(0)
  feeUsd             Float
  /** Platform cut of plugin monetization (USD). */
  platformShareUsd   Float     @default(0)
  /** Developer cut credited to wallet (USD). */
  developerShareUsd  Float     @default(0)
  breakdownJson      Json
  metadataJson       Json      @default("{}")
  balanceAfterUsd    Float
  createdAt          DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([source, createdAt])
  @@index([referenceId])
}

/**
 * Developer marketplace listing — external MCP/tool extensions.
 * Scoped to Workspace for multi-tenant isolation; developerId is the publisher.
 */
model AgentPlugin {
  id          String     @id @default(uuid())
  name        String
  developerId String
  /** Developer payout wallet / account id (public handle — not a secret key). */
  walletId    String?
  pricePerRun Float      @default(0.001)
  /** JSON description of custom tool capabilities (MCP schema). */
  mcpSchema   String     @db.Text
  version     String     @default("1.0.0")
  description String?    @db.Text
  /** Lifetime developer revenue credited from splits (USD). */
  revenueUsd  Float      @default(0)
  runCount    Int        @default(0)
  isActive    Boolean    @default(true)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([developerId])
  @@index([walletId])
  @@index([workspaceId, isActive])
  @@index([isActive, createdAt])
  @@index([workspaceId, name, developerId])
}

/**
 * Developer marketplace wallet — accumulates split revenue across tenants.
 * Isolated from Workspace balances; never stores API secrets.
 */
model DeveloperWallet {
  id            String   @id @default(uuid())
  developerId   String   @unique
  walletId      String
  balanceUsd    Float    @default(0)
  lifetimeUsd   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletId])
}

/**
 * Physical estate IoT / relay endpoints (LAN-only).
 * kind: gate_power | parking_lights | generic
 * protocol: SHELLY | SONOFF | GENERIC
 */
enum EstateDeviceProtocol {
  SHELLY
  SONOFF
  GENERIC
}

model EstateDevice {
  id          String               @id @default(uuid())
  name        String
  kind        String
  /** Preferred LAN IPv4, e.g. 192.168.1.50 */
  targetIp    String?
  /** SHELLY | SONOFF | GENERIC driver selection */
  protocol    EstateDeviceProtocol @default(GENERIC)
  /** Relay / switch channel index (Shelly id / Gen1 relay N) */
  channelId   Int                  @default(0)
  /** Legacy alias — prefer targetIp */
  ipAddress   String?
  /** Optional full override URL for GENERIC drivers */
  endpointUrl String?
  isActive    Boolean              @default(true)
  workspaceId String?
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([workspaceId, kind, isActive])
  @@index([workspaceId, isActive])
  @@index([workspaceId, protocol])
}

/**
 * Tenant-scoped telemetry warning rules (threshold / channel config).
 * Evaluated by alertRuleProcessor against workspace meter + error signals.
 */
model TelemetryAlertRule {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** Operator-facing label, unique per workspace. */
  name         String
  /** compute_gas_cost | meter_spend_usd | meter_balance_usd | unresolved_errors | plugin_fee_usd_1h */
  metric       String
  /** gt | gte | lt | lte | eq */
  operator     String    @default("gt")
  threshold    Float
  /** Channel targets: { webhook?: string, telegram?: boolean, whatsapp?: boolean } */
  channelsJson Json      @default("{}")
  enabled      Boolean   @default(true)
  /** Minimum seconds between fires for the same rule. */
  cooldownSec  Int       @default(300)
  lastFiredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, enabled])
  @@index([workspaceId, metric])
  @@index([lastFiredAt])
}

/**
 * Runtime failure telemetry for the autonomous self-healing pipeline.
 * patchApplied / explanation filled by POST /api/agents/heal.
 */
model AppErrorLog {
  id           String     @id @default(uuid())
  route        String
  errorMessage String     @db.Text
  stackTrace   String?    @db.Text
  resolved     Boolean    @default(false)
  /** Unified diff patch proposed by the AI healer. */
  patchApplied String?    @db.Text
  /** Architectural explanation of the proposed fix. */
  explanation  String?    @db.Text
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([resolved, createdAt])
  @@index([createdAt])
  @@index([route])
  @@index([workspaceId, resolved, createdAt])
}

/**
 * Physical IoT hardware endpoints for estate tenancies (Meerendal, etc.).
 */
model EstateIotDevice {
  id           String   @id
  name         String
  endpointUrl  String
  /** rest | shelly | sonoff */
  protocol     String   @default("rest")
  workspaceKey String   @default("meerendal")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceKey])
}

generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

}



enum AgentStatus {

  IDLE

  PLANNING

  EXECUTING

  REFLECTING

  ACTIVE

  PAUSED

  ERROR

}



enum UserRole {

  USER

  SUPER_ADMIN

}



enum SubscriptionTier {

  STARTER_5

  GROWTH_10

  PRO_20

  SCALE_50

  ENTERPRISE_100

  OVERLORD_500

}



enum OrgRole {

  OWNER

  ADMIN

  MEMBER

}



model User {

  id           String           @id @default(cuid())

  name         String?

  email        String           @unique

  password     String

  role         UserRole         @default(USER)

  tier         SubscriptionTier @default(STARTER_5)

  maxAgents    Int              @default(5)

  plan         String           @default("FREE")

  agents       Agent[]

  swarmSessions SwarmSession[]

  memberships  OrgMembership[]

  workspaceMemories WorkspaceMemory[]

  subscription Subscription?

  createdAt    DateTime         @default(now())

  updatedAt    DateTime         @updatedAt

}



model Subscription {

  id        String           @id @default(cuid())

  userId    String           @unique

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier      SubscriptionTier

  maxAgents Int

  status    String           @default("active")

  createdAt DateTime         @default(now())

  updatedAt DateTime         @updatedAt

}



model Agent {

  id          String      @id @default(cuid())

  name        String

  status      AgentStatus @default(IDLE)

  objective   String

  currentTask String?

  memoryBank  Json        @default("[]")

  ownerId     String?

  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())

  updatedAt   DateTime    @updatedAt



  @@index([ownerId])

}

model SystemSnapshot {
  id                String   @id @default(uuid())
  branch            String
  lastCommit        String
  activeAgentsCount Int
  timestamp         DateTime @default(now())
}

model SwarmSession {
  id                     String   @id @default(cuid())
  userId                 String
  orgId                  String?
  objective              String
  resultMarkdown         String   @db.Text
  kernelLogs             String   @db.Text
  /** ACTIVE | PAUSED | PENDING_CONSENSUS | COMPLETED | FAILED | TIMEOUT */
  status                 String   @default("COMPLETED")
  /** Operator HITL directive; cleared after the stream loop consumes it. */
  interventionDirective  String?  @db.Text
  /** Human debate vote: creator | critic — cleared after the loop consumes it. */
  consensusVote          String?
  /** Wall-clock duration of the swarm run in milliseconds. */
  durationMs             Int      @default(0)
  /** Execution credit units consumed by this run. */
  creditsUsed            Int      @default(0)
  /** Optional tokens estimate (chars/4 heuristic when provider tokens unavailable). */
  tokensUsed             Int      @default(0)
  /** Persona label used for the run (Researcher, Security, Custom, …). */
  persona                String?
  /** True when the run entered PAUSED / received an operator intervention. */
  hitlUsed               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([userId, orgId, createdAt])
  @@index([orgId, createdAt])
  @@index([createdAt])
  @@index([status])
}

model Organization {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  memberships OrgMembership[]
  sessions    SwarmSession[]
  memories    WorkspaceMemory[]
}

model WorkspaceMemory {
  id        String        @id @default(cuid())
  orgId     String?
  userId    String
  fragment  String        @db.Text
  keywords  String[]
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([createdAt])
}

model OrgMembership {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  role         OrgRole      @default(MEMBER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

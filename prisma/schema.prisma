generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "postgresql"

}



enum AgentStatus {

  IDLE

  PLANNING

  EXECUTING

  REFLECTING

  ACTIVE

  PAUSED

  ERROR

}



enum UserRole {

  USER

  SUPER_ADMIN

}

/**
 * Profile role hierarchy — absolute tier boundary for advanced tooling.
 * USER_ACCOUNT: standard tenant operator (no script sandbox / orchestration).
 * DEVELOPER_ACCOUNT: verified developer profile with sandbox + advanced flags.
 */
enum AccountProfileKind {
  USER_ACCOUNT
  DEVELOPER_ACCOUNT
}

/**
 * Workspace authorization floor required to touch advanced tools / containers.
 * BASIC < ADVANCED_TOOLS < CONTAINER_ORCHESTRATION
 */
enum WorkspaceAuthLevel {
  BASIC
  ADVANCED_TOOLS
  CONTAINER_ORCHESTRATION
}



enum SubscriptionTier {

  STARTER_5

  GROWTH_10

  PRO_20

  SCALE_50

  ENTERPRISE_100

  OVERLORD_500

}



enum OrgRole {

  OWNER

  ADMIN

  MEMBER

}



/** Navigation / viewport mode for tenant dashboards (edge-mirrored). */
enum UiPreference {
  USER
  DEVELOPER
}



model User {

  id           String           @id @default(cuid())

  name         String?

  email        String           @unique

  phone        String?

  password     String

  role         UserRole         @default(USER)

  /** Absolute profile tier — USER_ACCOUNT vs DEVELOPER_ACCOUNT hierarchy. */
  accountKind  AccountProfileKind @default(USER_ACCOUNT)

  tier         SubscriptionTier @default(STARTER_5)

  maxAgents    Int              @default(5)

  plan         String           @default("FREE")

  emailCode           String?
  emailCodeExpiresAt  DateTime?
  phoneCode           String?
  phoneCodeExpiresAt  DateTime?
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?

  agents       Agent[]

  swarmSessions SwarmSession[]

  memberships  OrgMembership[]

  workspaceMemories WorkspaceMemory[]

  agentTokens  AgentTokenVault[]

  mcpHosts     McpHost[]

  subscription Subscription?

  /** Present only when accountKind = DEVELOPER_ACCOUNT and verification succeeded. */
  developerAccount DeveloperAccount?

  createdAt    DateTime         @default(now())

  updatedAt    DateTime         @updatedAt

  @@index([accountKind])

}

/**
 * Verified developer profile — gates script sandboxes & container orchestration.
 * Linked 1:1 to User; absent for USER_ACCOUNT tier.
 */
model DeveloperAccount {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** Public developer handle (not a secret). */
  handle                 String?
  /** Wall-clock verification timestamp — null means pending / revoked. */
  verifiedAt             DateTime?
  sandboxEnabled         Boolean                @default(true)
  orchestrationEnabled   Boolean                @default(false)
  /** Soft caps for virtual runtime telemetry. */
  maxConcurrentRuntimes  Int                    @default(2)
  maxCpuMsPerDay         Int                    @default(600000)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  sandboxMetrics         SandboxRuntimeMetric[]

  @@index([verifiedAt])
  @@index([sandboxEnabled, verifiedAt])
}



model Subscription {

  id        String           @id @default(cuid())

  userId    String           @unique

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  tier      SubscriptionTier

  maxAgents Int

  status    String           @default("active")

  createdAt DateTime         @default(now())

  updatedAt DateTime         @updatedAt

}



model Agent {

  id          String      @id @default(cuid())

  name        String

  status      AgentStatus @default(IDLE)

  objective   String

  currentTask String?

  memoryBank  Json        @default("[]")

  ownerId     String?

  owner       User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())

  updatedAt   DateTime    @updatedAt



  @@index([ownerId])

}

model SystemSnapshot {
  id                String   @id @default(uuid())
  branch            String
  lastCommit        String
  activeAgentsCount Int
  timestamp         DateTime @default(now())
}

model SwarmSession {
  id                     String   @id @default(cuid())
  userId                 String
  orgId                  String?
  objective              String
  resultMarkdown         String   @db.Text
  kernelLogs             String   @db.Text
  /** ACTIVE | PAUSED | PENDING_CONSENSUS | COMPLETED | FAILED | TIMEOUT */
  status                 String   @default("COMPLETED")
  /** Operator HITL directive; cleared after the stream loop consumes it. */
  interventionDirective  String?  @db.Text
  /** Human debate vote: creator | critic — cleared after the loop consumes it. */
  consensusVote          String?
  /** Wall-clock duration of the swarm run in milliseconds. */
  durationMs             Int      @default(0)
  /** Execution credit units consumed by this run. */
  creditsUsed            Int      @default(0)
  /** Optional tokens estimate (chars/4 heuristic when provider tokens unavailable). */
  tokensUsed             Int      @default(0)
  /** Persona label used for the run (Researcher, Security, Custom, …). */
  persona                String?
  /** True when the run entered PAUSED / received an operator intervention. */
  hitlUsed               Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization           Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([userId, orgId, createdAt])
  @@index([orgId, createdAt])
  @@index([createdAt])
  @@index([status])
}

model Organization {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  memberships OrgMembership[]
  sessions    SwarmSession[]
  memories    WorkspaceMemory[]
  plugins     WorkspacePlugin[]
  agentTokens AgentTokenVault[]
  mcpHosts    McpHost[]
}

enum AgentTokenKind {
  LIVE
  TEST
  SERVICE
}

/**
 * Token Vault — store keyPrefix + keyHash + sealed Edge claims only.
 * Never persist raw ss_live_* secrets. sealedPayload uses ss:iv:tag:cipher.
 */
model AgentTokenVault {
  id            String         @id @default(cuid())
  keyPrefix     String
  keyHash       String         @unique
  sealedPayload String
  kind          AgentTokenKind @default(LIVE)
  label         String?
  scopes        String[]
  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  orgId         String?
  organization  Organization?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  expiresAt     DateTime?
  revokedAt     DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
  @@index([orgId])
  @@index([keyPrefix])
  @@index([revokedAt])
  @@index([workspaceId])
}

enum McpTransportKind {
  HTTP
  SSE
}

/**
 * Registered remote MCP hosts (streamable HTTP / SSE).
 * authTokenCipher uses the same AES-GCM envelope as WorkspacePlugin.authToken.
 */
model McpHost {
  id              String           @id @default(cuid())
  name            String
  url             String
  transport       McpTransportKind @default(HTTP)
  authTokenCipher String?
  isActive        Boolean          @default(true)
  orgId           String?
  organization    Organization?    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerId         String?
  owner           User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspaceId     String?
  workspace       Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lastToolListAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([orgId, isActive])
  @@index([ownerId])
  @@index([workspaceId, isActive])
}

/**
 * External OpenAPI-backed tools scoped to a workspace (Organization).
 * authToken is AES-256-GCM ciphertext with an "ss..." prefix when present.
 */
model WorkspacePlugin {
  id          String        @id @default(uuid())
  name        String
  /** Parsed OpenAPI paths & schemas for dynamic tool compilation. */
  spec        Json
  baseUrl     String
  /** "none" | "bearer" | "apiKey" */
  authType    String
  /** e.g. "Authorization" or "x-api-key" */
  authHeader  String
  /** Securely encrypted string with "ss..." prefix; null when authType is "none". */
  authToken   String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspaceId String?
  workspace   Organization? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model WorkspaceMemory {
  id        String        @id @default(cuid())
  orgId     String?
  userId    String
  fragment  String        @db.Text
  keywords  String[]
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orgId])
  @@index([createdAt])
}

model OrgMembership {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  role         OrgRole      @default(MEMBER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId])
}

/**
 * Multi-tenant heal / MCP scope. apiKey authenticates workspace-scoped telemetry + heal.
 * credentialCipher holds AES-256-GCM sealed injection secrets (ssv1:…); never return raw.
 */
model Workspace {
  id                String               @id @default(uuid())
  name              String
  apiKey            String               @unique
  /** Sealed tenant credential blob (vault AES-256-GCM). */
  credentialCipher  String?              @db.Text
  /** Prepaid utility balance in USD for metered agent execution. */
  meterBalanceUsd   Float                @default(25)
  /** Lifetime metered spend in USD. */
  meterSpendUsd     Float                @default(0)
  meterLastAt       DateTime?
  /** Tenant navigation / viewport mode — mirrored to Edge KV on write. */
  uiPreference      UiPreference         @default(USER)
  /**
   * Minimum AccountProfileKind / capability floor for this workspace.
   * ADVANCED_TOOLS + CONTAINER_ORCHESTRATION require a verified DeveloperAccount.
   */
  requiredAuthLevel WorkspaceAuthLevel   @default(BASIC)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  logs              AppErrorLog[]
  hosts             McpHost[]
  tokens            AgentTokenVault[]
  devices           EstateDevice[]
  plugins           AgentPlugin[]
  meterEvents       WorkspaceMeterEvent[]
  alertRules        TelemetryAlertRule[]
  auditLogs         TelemetryAuditLog[]
  settings          WorkspaceSettings?
  sandboxMetrics    SandboxRuntimeMetric[]
  catalogItems      CatalogItem[]

  @@index([createdAt])
  @@index([meterLastAt])
  @@index([uiPreference])
  @@index([requiredAuthLevel])
}

/**
 * Virtual sandbox runtime telemetry bound to a verified DeveloperAccount.
 * Tracks CPU / memory / disk for script compilation & container-adjacent runs.
 */
model SandboxRuntimeMetric {
  id                  String            @id @default(uuid())
  developerAccountId  String
  developerAccount    DeveloperAccount  @relation(fields: [developerAccountId], references: [id], onDelete: Cascade)
  workspaceId         String?
  workspace           Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  /** Opaque virtual system runtime identifier. */
  runtimeId           String
  /** javascript | python | container | other */
  language            String?
  cpuMs               Int               @default(0)
  memoryMbPeak        Int               @default(0)
  diskMb              Int               @default(0)
  exitCode            Int?
  /** active | completed | failed | killed */
  status              String            @default("completed")
  metadataJson        Json              @default("{}")
  startedAt           DateTime          @default(now())
  endedAt             DateTime?
  createdAt           DateTime          @default(now())

  @@index([developerAccountId, createdAt(sort: Desc)])
  @@index([developerAccountId, runtimeId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

/**
 * Tenant workspace configuration + platform feature flags.
 * One row per workspace; mirrored to Edge KV on write for middleware reads.
 */
model WorkspaceSettings {
  id               String    @id @default(uuid())
  workspaceId      String    @unique
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** Ordered custom configuration entries (key/value/meta arrays). */
  configJson       Json      @default("[]")
  /** Active feature flag map: { flagKey: boolean }. */
  featureFlagsJson Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([updatedAt])
}

/**
 * Micro-transaction log for utility-metered execution (heal, sandbox, plugins).
 * No credential material — fee breakdown only.
 */
model WorkspaceMeterEvent {
  id                 String    @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** heal | sandbox | manual | plugin */
  source             String
  referenceId        String?
  inputTokens        Int       @default(0)
  correctionCycles   Int       @default(0)
  notificationsSent  Int       @default(0)
  pluginsInvoked     Int       @default(0)
  feeUsd             Float
  /** Platform cut of plugin monetization (USD). */
  platformShareUsd   Float     @default(0)
  /** Developer cut credited to wallet (USD). */
  developerShareUsd  Float     @default(0)
  breakdownJson      Json
  metadataJson       Json      @default("{}")
  balanceAfterUsd    Float
  createdAt          DateTime  @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, source, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@index([referenceId])
}

/**
 * Developer marketplace listing — external MCP/tool extensions.
 * Scoped to Workspace for multi-tenant isolation; developerId is the publisher.
 */
model AgentPlugin {
  id          String     @id @default(uuid())
  name        String
  developerId String
  /** Developer payout wallet / account id (public handle — not a secret key). */
  walletId    String?
  pricePerRun Float      @default(0.001)
  /** JSON description of custom tool capabilities (MCP schema). */
  mcpSchema   String     @db.Text
  version     String     @default("1.0.0")
  description String?    @db.Text
  /** Lifetime developer revenue credited from splits (USD). */
  revenueUsd  Float      @default(0)
  runCount    Int        @default(0)
  isActive    Boolean    @default(true)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([developerId])
  @@index([walletId])
  @@index([workspaceId, isActive])
  @@index([isActive, createdAt])
  @@index([workspaceId, name, developerId])
}

/**
 * Developer marketplace wallet — accumulates split revenue across tenants.
 * Isolated from Workspace balances; never stores API secrets.
 */
model DeveloperWallet {
  id            String   @id @default(uuid())
  developerId   String   @unique
  walletId      String
  balanceUsd    Float    @default(0)
  lifetimeUsd   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([walletId])
}

/**
 * Physical estate IoT / relay endpoints (LAN-only).
 * kind: gate_power | parking_lights | generic
 * protocol: SHELLY | SONOFF | GENERIC
 */
enum EstateDeviceProtocol {
  SHELLY
  SONOFF
  GENERIC
}

model EstateDevice {
  id          String               @id @default(uuid())
  name        String
  kind        String
  /** Preferred LAN IPv4, e.g. 192.168.1.50 */
  targetIp    String?
  /** SHELLY | SONOFF | GENERIC driver selection */
  protocol    EstateDeviceProtocol @default(GENERIC)
  /** Relay / switch channel index (Shelly id / Gen1 relay N) */
  channelId   Int                  @default(0)
  /** Legacy alias — prefer targetIp */
  ipAddress   String?
  /** Optional full override URL for GENERIC drivers */
  endpointUrl String?
  isActive    Boolean              @default(true)
  workspaceId String?
  workspace   Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([workspaceId, kind, isActive])
  @@index([workspaceId, isActive])
  @@index([workspaceId, protocol])
}

/**
 * Tenant-scoped telemetry warning rules (threshold / channel config).
 * Evaluated by alertRuleProcessor against workspace meter + error signals.
 */
model TelemetryAlertRule {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** Operator-facing label, unique per workspace. */
  name         String
  /** compute_gas_cost | meter_spend_usd | meter_balance_usd | unresolved_errors | plugin_fee_usd_1h */
  metric       String
  /** gt | gte | lt | lte | eq */
  operator     String    @default("gt")
  threshold    Float
  /** Channel targets: { webhook?: string, telegram?: boolean, whatsapp?: boolean } */
  channelsJson Json      @default("{}")
  enabled      Boolean   @default(true)
  /** Minimum seconds between fires for the same rule. */
  cooldownSec  Int       @default(300)
  lastFiredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, enabled])
  @@index([workspaceId, metric])
  @@index([lastFiredAt])
}

/**
 * Persistent tenant security / compliance audit trail.
 * High-volume append-only; indexed for workspace-scoped time-series reads.
 */
model TelemetryAuditLog {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  /** Dot-namespaced action, e.g. auth.api_key.rotate, alert.rule.upsert */
  action       String
  /** user | api_key | system | agent */
  actorType    String
  actorId      String?
  /** Resource kind, e.g. workspace, alert_rule, mcp_host */
  resource     String?
  resourceId   String?
  /** success | denied | failed */
  outcome      String    @default("success")
  /** Optional SHA-256 of client IP — never store raw IP. */
  ipHash       String?
  userAgent    String?   @db.VarChar(512)
  metadataJson Json      @default("{}")
  createdAt    DateTime  @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, action, createdAt(sort: Desc)])
  @@index([workspaceId, outcome, createdAt(sort: Desc)])
  @@index([workspaceId, actorType, createdAt(sort: Desc)])
  @@index([workspaceId, resource, resourceId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

/**
 * Runtime failure telemetry for the autonomous self-healing pipeline.
 * patchApplied / explanation filled by POST /api/agents/heal.
 */
model AppErrorLog {
  id           String     @id @default(uuid())
  route        String
  errorMessage String     @db.Text
  stackTrace   String?    @db.Text
  resolved     Boolean    @default(false)
  /** Unified diff patch proposed by the AI healer. */
  patchApplied String?    @db.Text
  /** Architectural explanation of the proposed fix. */
  explanation  String?    @db.Text
  workspaceId  String?
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([resolved, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([route, createdAt(sort: Desc)])
  @@index([workspaceId, resolved, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
}

/**
 * Physical IoT hardware endpoints for estate tenancies (Meerendal, etc.).
 */
model EstateIotDevice {
  id           String   @id
  name         String
  endpointUrl  String
  /** rest | shelly | sonoff */
  protocol     String   @default("rest")
  workspaceKey String   @default("meerendal")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceKey])
}

// ─────────────────────────────────────────────────────────────────────────────
// E-Commerce Catalog
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Lifecycle status for tenant catalog items.
 * DELETED is a soft-delete tombstone; never hard-removed from the table.
 */
enum CatalogItemStatus {
  ACTIVE
  DRAFT
  ARCHIVED
  DELETED
}

/**
 * Multi-tenant e-commerce catalog item.
 * Strictly scoped to a single Workspace — cross-tenant access is blocked at API layer.
 * SKU uniqueness is enforced per workspace (not globally).
 */
model CatalogItem {
  id            String            @id @default(uuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title         String
  description   String?           @db.Text
  /** Price in minor units expressed as a float (e.g. 149.99 = ZAR 149.99). */
  price         Float
  sku           String
  category      String
  stockQuantity Int               @default(0)
  /** Ordered array of public image URLs. */
  images        String[]
  status        CatalogItemStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([workspaceId, sku])
  @@index([workspaceId, status])
  @@index([workspaceId, category, status])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([workspaceId, status, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// SRE Telemetry
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Append-only SRE telemetry log — one row per health-check tick or pipeline probe.
 * status: healthy | degraded | critical | unknown
 * fixedBySre: true when the autonomous SRE pipeline applied a remediation patch.
 */
model SreSystemLog {
  id          String   @id @default(uuid())
  serviceName String
  /** healthy | degraded | critical | unknown */
  status      String   @default("healthy")
  latencyMs   Int      @default(0)
  errorStack  String?  @db.Text
  fixedBySre  Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([serviceName, timestamp(sort: Desc)])
  @@index([status, timestamp(sort: Desc)])
  @@index([fixedBySre, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
}

# ─── Database (Neon Postgres) — REQUIRED FIRST ───────────────────────────────
# Replace with your Neon connection string from console.neon.tech
# Example:
DATABASE_URL="postgresql://<username>:<password>@<host>.neon.tech/neondb?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"

# ─── Stripe (Test Mode) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_STARTER_PRICE_ID="price_your_starter_price_id"
STRIPE_PREMIUM_PRICE_ID="price_your_premium_price_id"
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID="price_your_starter_price_id"
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID="price_your_premium_price_id"

# ─── Contact / Support ───────────────────────────────────────────────────────
DISCORD_SUPPORT_WEBHOOK_URL="https://discord.com/api/webhooks/your_webhook_id/your_webhook_token"

# ─── BVNK Crypto (Sandbox) ──────────────────────────────────────────────────
BVNK_HAWK_AUTH_ID="your_hawk_auth_id"
BVNK_HAWK_AUTH_KEY="your_hawk_auth_key"
BVNK_API_KEY="your_hawk_auth_id"
BVNK_API_SECRET="your_hawk_auth_key"
BVNK_MERCHANT_ID="your_bvnk_merchant_uuid"
BVNK_WALLET_ID="your_bvnk_wallet_id"
BVNK_WEBHOOK_SECRET="your_bvnk_webhook_secret"
BVNK_API_BASE_URL="https://api.sandbox.bvnk.com"

# ─── Integration Credentials ─────────────────────────────────────────────────
# Min 32 chars — used to AES-256-GCM encrypt HubSpot/Salesforce/OpenAI keys at rest
INTEGRATION_ENCRYPTION_KEY="replace-with-openssl-rand-base64-32-min-32-chars"

# ─── Workspace Plugins (OpenAPI tools) ───────────────────────────────────────
# 32-byte key as 64 hex characters — encrypts plugin authToken at rest (ss:iv:tag:cipher)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLUGINS_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# ─── Agentic Edge / Token Vault / MCP ───────────────────────────────────────
# 64 hex chars for Edge sealed-token decrypt (defaults to PLUGINS_ENCRYPTION_KEY)
TOKEN_VAULT_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# Optional SHA-256 hex of one permitted ss_live_* key
# AGENT_TOKEN_ALLOWLIST_HASH=
# Master agent Bearer for /api/workspaces and /api/agents/heal
# MASTER_AGENT_TOKEN="ss_live_..."
# Set to 1 to require Bearer/x-agent-token on all matched agent API routes
AGENT_MIDDLEWARE_STRICT=0

# ─── Self-healing agent (Feature 7) ─────────────────────────────────────────
# Uses OPENAI_API_KEY + optional OPENAI_BASE_URL (or Neon AI Gateway aliases).
# Without a key, heal returns an offline deterministic patch proposal.
# HEAL_AGENT_MODEL=gpt-4o-mini
# Optional repo-relative sandbox for healer FS tools (defaults to project root)
# HEAL_SANDBOX_DIR=.
# Optional notify webhooks (omit → console mock "sent")
# HEAL_WHATSAPP_WEBHOOK_URL=
# HEAL_TELEGRAM_WEBHOOK_URL=
# HEAL_NOTIFY_WEBHOOK_URL=
# Estate IoT LAN relays (optional — register via EstateDevice rows)
# Devices must use private IPs only (10.x / 172.16-31.x / 192.168.x); 3s timeout
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# ─── App URL (checkout redirects) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ─── Dev identity / monetization overrides ──────────────────────────────────
# DEV_USER_ROLE=SUPER_ADMIN
# DEV_USER_TIER=OVERLORD_500
# DEV_USER_PLAN=FREE
# FREE_STREAM_QUOTA=3
# BVNK_WEBHOOK_ALLOW_UNSIGNED=1


{
  "name": "scalesystems",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "clean": "node ./scripts/clean-next-cache.js",
    "dev:clean": "npm run clean && next dev --turbopack -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:verify-indexes": "node --env-file=.env scripts/verify-db-indexes.mjs",
    "db:seed:mcp": "node --env-file=.env scripts/seed-mcp-hosts.mjs",
    "snapshot": "node ./scripts/system-snapshot.js",
    "close-session": "npm run snapshot && git add . && git commit -m \"Dev Session Sync\" --allow-empty && git push origin development"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^2.0.14",
    "@ai-sdk/openai": "^4.0.15",
    "@auth/prisma-adapter": "^2.11.2",
    "@e2b/code-interpreter": "^2.6.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.9.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.67.0",
    "@sparticuz/chromium": "^149.0.0",
    "@vercel/blob": "^2.6.1",
    "@vercel/kv": "^3.0.0",
    "@xyflow/react": "^12.11.2",
    "ai": "^7.0.29",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "next": "^16.2.11",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "three": "^0.185.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^7.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "@sentry/cli@2.58.6": true,
    "bcrypt@6.0.0": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}

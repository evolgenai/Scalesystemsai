{
  "name": "scalesystems",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "env:generate": "node scripts/generate-env.mjs",
    "stripe:login": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1 login",
    "stripe:listen": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1 listen --forward-to http://127.0.0.1:3000/api/webhooks/stripe",
    "stripe:version": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1 --version",
    "stripe:setup-premium": "powershell -ExecutionPolicy Bypass -File scripts/setup-stripe-premium.ps1",
    "db:push": "prisma db push",
    "db:setup-neon": "powershell -ExecutionPolicy Bypass -File scripts/setup-neon-cli.ps1",
    "db:setup-local": "powershell -ExecutionPolicy Bypass -File scripts/setup-local-postgres.ps1",
    "db:verify": "node scripts/verify-neon-sync.mjs",
    "db:verify:push": "prisma db push",
    "bvnk:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-bvnk.ps1",
    "bvnk:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-bvnk-env.ps1",
    "bvnk:verify": "node scripts/verify-bvnk.mjs",
    "integrations:verify": "node scripts/verify-integrations.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.9.0",
    "@types/hawk": "^9.0.7",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.18.0",
    "hawk": "^9.0.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.3.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
